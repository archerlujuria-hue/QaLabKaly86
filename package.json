{
  "//_info": "=== METADATOS DEL PROYECTO ===",
  "name": "qa-lab-kaly86", // El nombre oficial de tu repositorio de QA.
  "version": "1.0.0", // La versión actual de tu suite de pruebas.
  "description": "Laboratorio de QA Automation con integración a Jira Xray", // Qué hace el proyecto.
  "main": "index.js", // El punto de entrada principal del código (si lo hubiera).

  "//_scripts": "=== COMANDOS PERSONALIZADOS (Ej: npm run test:ci) ===",
  "scripts": {
    "test": "jest", // Ejecuta los tests localmente de forma simple.
    "test:ci": "jest --reporters=default --reporters=jest-junit" // ¡ESTE ES CLAVE! Corre Jest en GitHub y le ordena generar el XML para Jira.
  },

  "//_keywords": "=== PALABRAS CLAVE PARA BUSCAR ESTE REPOSITORIO ===",
  "keywords": [
    "qa",
    "testing",
    "xray",
    "jira",
    "jest"
  ],

  "//_author": "=== AUTOR Y LICENCIA DEL PROYECTO ===",
  "author": "Kaly El Dandy", // ¡Tu firma como creador!
  "license": "ISC", // Licencia estándar de uso.

  "//_dependencies": "=== LIBRERÍAS DE DESARROLLO (Instaladas con npm install) ===",
  "devDependencies": {
    "jest": "^29.7.0", // El framework de JavaScript para ejecutar los tests.
    "jest-junit": "^16.0.0" // El plugin que traduce los resultados de Jest al formato JUnit XML que lee Jira.
  },

  "//_config": "=== CONFIGURACIÓN DE REPORTES JUNIT PARA JIRA XRAY ===",
  "jest-junit": {
    "outputDirectory": ".", // Le dice a Jest que guarde el archivo XML en la raíz del proyecto.
    "outputName": "results.xml" // Le da el nombre exacto 'results.xml' que buscará GitHub Actions.
  }
}
